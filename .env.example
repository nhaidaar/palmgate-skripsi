# PalmGate runtime configuration

# Default model layout: models/<MODEL_VERSION>/model.tflite
MODEL_VERSION=embedding_new_roi_v2

# Optional explicit overrides. MODEL_PATH wins over MODEL_VERSION when set.
# MODEL_PATH=models/embedding_new_roi_v2/model.tflite
# MODEL_METADATA_PATH=models/embedding_new_roi_v2/model_metadata.json

# Docker Compose defaults to USB mode after copying this file to .env.
COMPOSE_PROFILES=usb
PALMGATE_MODELS_DIR=./models

# Camera device (used for both Docker mapping and runtime)
CAMERA_DEVICE_PATH=/dev/video0

# Runtime mode
DEVICE_RUNTIME_ENABLED=1
CAMERA_SOURCE=usb

# Database
DB_PATH=palmprint.db
